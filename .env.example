# =====================================================================
# ED Triage Console — environment configuration
# Copy to .env for local use. Nothing here is a production secret; the demo
# credential store lives in auth.py (academic prototype).
# =====================================================================

# ---- Application ----------------------------------------------------
# Signing key for the session cookie. Set a long random value in production.
# ED_SECRET_KEY=change-me-to-a-long-random-string
# DB location. Defaults to ./ed.db. Serverless hosts must use /tmp.
# ED_DB_PATH=/tmp/ed.db

# ---- Turso / libSQL (opt-in: PERSISTENT DB for serverless / Vercel) ----
# When LIBSQL_URL is set the app uses Turso instead of a local file, so the
# audit chain and all writes persist even on stateless hosts. Requires
# `pip install -r requirements-turso.txt`. Leave unset for local sqlite.
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=your-turso-token

# ---- AI SERVICE BOUNDARY (the MODE 1 / MODE 2 switch) ---------------
# false = MODE 1: Vercel / AI-off. The app runs fully; /api/ai/* return a
#         clean "disabled" state; ZERO calls to Ollama.
# true  = MODE 2: full local stack with the Advanced RAG copilot.
AI_ENABLED=true

# ---- Local AI: Ollama (only used when AI_ENABLED=true) --------------
OLLAMA_HOST=http://localhost:11434
ED_GEN_MODEL=gemma4:31b
ED_EMBED_MODEL=nomic-embed-text
ED_GEN_TIMEOUT=180
ED_EMBED_TIMEOUT=45

# ---- Retrieval knobs -----------------------------------------------
DENSE_TOP_K=8
SPARSE_TOP_K=8
RRF_K=60
RERANK_TOP_K=6
CONTEXT_TOKEN_BUDGET=1800

# ---- Advanced RAG feature flags (adaptive; only fire when useful) ---
ENABLE_QUERY_CLASSIFICATION=true
ENABLE_QUERY_REWRITE=true
ENABLE_QUERY_DECOMPOSITION=true
ENABLE_MULTI_QUERY=false
ENABLE_HYDE=false
ENABLE_RERANKING=true
ENABLE_CONTEXTUAL_COMPRESSION=true
ENABLE_CORRECTIVE_RETRIEVAL=true
MAX_CORRECTIVE_ITERATIONS=1
MAX_SUBQUERIES=3
